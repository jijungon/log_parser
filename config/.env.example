# log_parser 환경변수
# 복사 후 실제 값 입력: cp config/.env.example config/.env

# ── 필수 ──────────────────────────────────────────────────────────────────────

# 수신측 push 인증 토큰 (transport.token_env 에 지정된 이름과 일치해야 함)
# agent.yaml 의 transport.token_env 기본값: PUSH_OUTBOUND_TOKEN
PUSH_OUTBOUND_TOKEN=your-outbound-token-here

# /flush 엔드포인트 인증 토큰 (agent.yaml 의 inbound.token_env 기본값: FLUSH_INBOUND_TOKEN)
# 비워두면 인증 없이 허용 — 운영 환경에서는 반드시 설정
FLUSH_INBOUND_TOKEN=your-flush-token-here

# ── 선택 ──────────────────────────────────────────────────────────────────────

# categories.yaml 경로 (기본값: /etc/log_parser/categories.yaml)
CATEGORIES_PATH=/app/log_parser/config/categories.yaml

# Vector 런타임 config 출력 경로 (기본값: /run/log_parser/vector.toml)
# VECTOR_RUNTIME_CONFIG=/run/log_parser/vector.toml

# 로그 레벨: error | warn | info | debug | trace
# 모듈별 지정 예: log_parser=debug,vector=warn
RUST_LOG=info
