# log_parser 환경변수
# 복사 후 실제 값 입력: cp config/.env.example config/.env

# ── 필수: 토큰 4개 ────────────────────────────────────────────────────────────
# 넷 다 임의의 시크릿 문자열이다. 직접 생성한다 — 예: openssl rand -hex 32
# ⚠ 하나라도 미설정(빈 값)이면 에이전트 기동이 거부된다.
# ⚠ 값을 맞춰야 하는 상대가 있다:
#   - PUSH_OUTBOUND_TOKEN : 파서가 push할 때 붙이는 Bearer 토큰. 받는 쪽(수신 서버)이
#                           기대하는 값과 같아야 한다.
#   - FLUSH/STAT/SOS_INBOUND_TOKEN : 파서의 pull API 인증 토큰. 이 API를 호출하는
#                           소비자(예: log_stack_AI)가 보내는 값과 같아야 한다.

# 수신측 push 인증 토큰 (agent.yaml transport.token_env 기본 이름: PUSH_OUTBOUND_TOKEN)
PUSH_OUTBOUND_TOKEN=your-outbound-token-here

# /flush · /drain-spool · /drain-status 인증 토큰
FLUSH_INBOUND_TOKEN=your-flush-token-here

# /stat 인증 토큰
STAT_INBOUND_TOKEN=your-stat-token-here

# /trigger-sos 인증 토큰
SOS_INBOUND_TOKEN=your-sos-token-here

# ── 선택 ──────────────────────────────────────────────────────────────────────

# categories.yaml 경로 (기본값: /etc/log_parser/categories.yaml)
# CATEGORIES_PATH=/etc/log_parser/categories.yaml

# fields.yaml 경로 (기본값: /etc/log_parser/fields.yaml)
# FIELDS_PATH=/etc/log_parser/fields.yaml

# Vector 런타임 config 출력 경로 (기본값: /run/log_parser/vector.toml)
# VECTOR_RUNTIME_CONFIG=/run/log_parser/vector.toml

# 로그 레벨: error | warn | info | debug | trace
# 모듈별 지정 예: log_parser=debug,vector=warn
RUST_LOG=info
