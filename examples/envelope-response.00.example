━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
수신측 독해 순서
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

1. headers.counts.by_severity 확인
   → critical: 3 발견 → 즉시 "사고 가능성" 판단

2. headers.counts.by_category 확인
   → kernel.oom + disk.io_error 조합 → "디스크 문제로 OOM" 가설

3. body[0].data[] 파고들기
   → kernel.oom count=3, ts: 10:13:42 ~ 10:13:58
   → disk.io_error count=312 (30초 burst), ts: 10:03:00 ~ 10:03:29
   → 디스크 에러(10:03) → OOM(10:13) 인과 흐름 확인

4. 상세 수집 트리거 판단 (수신측)
   → "사고다" → GET /stat + POST /flush + POST /trigger-sos 병렬 호출

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
empty cycle 예시 (이벤트 0건, 호스트 alive 신호)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

